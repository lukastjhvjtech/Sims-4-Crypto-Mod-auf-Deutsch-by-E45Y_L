<?xml version="1.0" encoding="UTF-8"?>
<Root>
  <!-- Crypto Trading App für Sims 4 -->
  <!-- Diese UI kann sowohl auf dem Handy als auch am PC verwendet werden -->
  
  <Screen Name="CryptoTradingApp" Width="450" Height="650" Background="#0f0f0f">
    
    <!-- Header mit Titel und Gesamtportfolio-Wert -->
    <Header Text="📈 Crypto Trader" FontSize="20" Color="#ffffff" Y="10"/>
    <Text Name="TotalValue" Text="Gesamtwert: 0 §" Y="35" FontSize="14" Color="#4ade80"/>
    <Text Name="AvailableBalance" Text="Verfügbar: 0 §" Y="55" FontSize="12" Color="#9ca3af"/>
    
    <!-- Tabs für verschiedene Ansichten -->
    <TabGroup Y="80" Height="30">
      <Tab Name="MarketTab" Text="Markt" Selected="true" OnClick="show_market_view"/>
      <Tab Name="PortfolioTab" Text="Portfolio" OnClick="show_portfolio_view"/>
      <Tab Name="HistoryTab" Text="Verlauf" OnClick="show_history_view"/>
    </TabGroup>
    
    <!-- MARKT ANSICHT - Liste aller Kryptowährungen -->
    <Panel Name="MarketView" Y="115" Width="450" Height="320" Visible="true">
      <ScrollList Name="CryptoList" Width="430" Height="300" X="10" Y="0" Background="#1a1a1a">
        <!-- Template für jeden Crypto-Eintrag -->
        <ListItem Template="CryptoListItem">
          <Panel Width="410" Height="70" Background="#262626">
            <!-- Crypto Name und Icon -->
            <Text Name="CryptoName" Text="SimCoin" X="10" Y="5" FontSize="16" Color="#ffffff" Style="bold"/>
            <Text Name="CryptoSymbol" Text="SIM" X="10" Y="22" FontSize="10" Color="#6b7280"/>
            
            <!-- Mini Chart Vorschau -->
            <Image Name="MiniChart" Path="" X="120" Y="5" Width="100" Height="40"/>
            
            <!-- Aktueller Preis -->
            <Text Name="CurrentPrice" Text="25.00§" X="230" Y="10" FontSize="18" Color="#ffffff"/>
            <Text Name="PriceChange" Text="+5.2%" X="230" Y="30" FontSize="12" Color="#4ade80"/>
            
            <!-- Kaufen/Verkaufen Buttons -->
            <Button Name="BuyBtn" Text="Kaufen" X="320" Y="8" Width="80" Height="28" 
                    Background="#4ade80" Color="#000000" OnClick="buy_crypto"/>
            <Button Name="SellBtn" Text="Verkaufen" X="320" Y="40" Width="80" Height="28" 
                    Background="#ef4444" Color="#ffffff" OnClick="sell_crypto"/>
          </Panel>
        </ListItem>
      </ScrollList>
    </Panel>
    
    <!-- PORTFOLIO ANSICHT -->
    <Panel Name="PortfolioView" Y="115" Width="450" Height="320" Visible="false">
      <!-- Portfolio Übersicht Chart -->
      <Image Name="PortfolioChart" Path="charts/portfolio_overview.png" X="10" Y="0" Width="430" Height="150"/>
      
      <!-- Liste der持有的 Assets -->
      <ScrollList Name="HoldingsList" Width="430" Height="150" X="10" Y="160" Background="#1a1a1a">
        <ListItem Template="HoldingItem">
          <Panel Width="410" Height="45" Background="#262626">
            <Text Name="HoldingName" Text="SimCoin" X="10" Y="5" FontSize="14" Color="#ffffff"/>
            <Text Name="HoldingQty" Text="Menge: 10" X="10" Y="22" FontSize="11" Color="#9ca3af"/>
            <Text Name="HoldingValue" Text="Wert: 250§" X="250" Y="5" FontSize="14" Color="#4ade80"/>
            <Text Name="HoldingPrice" Text="@ 25.00§" X="250" Y="22" FontSize="11" Color="#6b7280"/>
          </Panel>
        </ListItem>
      </ScrollList>
    </Panel>
    
    <!-- VERLAUF ANSICHT -->
    <Panel Name="HistoryView" Y="115" Width="450" Height="320" Visible="false">
      <ScrollList Name="TransactionLog" Width="430" Height="300" X="10" Y="0" Background="#1a1a1a">
        <ListItem Template="LogEntry">
          <Text Name="LogText" Text="[01.01] 5 SimCoin für 125§ gekauft" X="10" Y="5" 
                FontSize="11" Color="#d1d5db" Width="410"/>
        </ListItem>
      </ScrollList>
    </Panel>
    
    <!-- Großes Chart Panel (wird bei Klick auf Crypto angezeigt) -->
    <Panel Name="DetailChartPanel" Y="440" Width="450" Height="160" Background="#1e1e1e" Visible="false">
      <Text Name="SelectedCryptoName" Text="SimCoin Details" X="10" Y="5" FontSize="14" Color="#ffffff"/>
      <Image Name="DetailChart" Path="" X="10" Y="25" Width="430" Height="125"/>
    </Panel>
    
    <!-- Aktionsbuttons unten -->
    <Panel Y="605" Width="450" Height="40">
      <Button Name="DepositBtn" Text="💰 Einzahlen" X="10" Y="5" Width="100" Height="30" 
              Background="#3b82f6" Color="#ffffff" OnClick="deposit_funds"/>
      <Button Name="WithdrawBtn" Text="💸 Abheben" X="120" Y="5" Width="100" Height="30" 
              Background="#f59e0b" Color="#000000" OnClick="withdraw_funds"/>
      <Button Name="RefreshBtn" Text="🔄 Aktualisieren" X="230" Y="5" Width="100" Height="30" 
              Background="#6b7280" Color="#ffffff" OnClick="refresh_data"/>
      <Button Name="CloseBtn" Text="✕ Schließen" X="340" Y="5" Width="100" Height="30" 
              Background="#ef4444" Color="#ffffff" OnClick="close_app"/>
    </Panel>
    
  </Screen>
  
  <!-- KAUFEN Dialog -->
  <Dialog Name="BuyDialog" Width="300" Height="200" Background="#1f2937" Modal="true">
    <Text Name="DialogTitle" Text="Kaufe Crypto" X="10" Y="10" FontSize="16" Color="#ffffff"/>
    <Text Name="BuyCryptoName" Text="SimCoin" X="10" Y="35" FontSize="14" Color="#4ade80"/>
    <Text Name="BuyCurrentPrice" Text="Preis: 25.00§" X="10" Y="55" FontSize="12" Color="#9ca3af"/>
    
    <InputField Name="QuantityInput" X="10" Y="80" Width="150" Height="30" 
                Placeholder="Anzahl" TextInputType="number"/>
    <Text Name="TotalCost" Text="Gesamt: 0§" X="10" Y="115" FontSize="14" Color="#ffffff"/>
    
    <Button Name="ConfirmBuy" Text="Kaufen" X="10" Y="150" Width="130" Height="35" 
            Background="#4ade80" Color="#000000" OnClick="confirm_buy"/>
    <Button Name="CancelBuy" Text="Abbrechen" X="155" Y="150" Width="130" Height="35" 
            Background="#6b7280" Color="#ffffff" OnClick="cancel_dialog"/>
  </Dialog>
  
  <!-- VERKAUFEN Dialog -->
  <Dialog Name="SellDialog" Width="300" Height="200" Background="#1f2937" Modal="true">
    <Text Name="SellDialogTitle" Text="Verkaufe Crypto" X="10" Y="10" FontSize="16" Color="#ffffff"/>
    <Text Name="SellCryptoName" Text="SimCoin" X="10" Y="35" FontSize="14" Color="#ef4444"/>
    <Text Name="SellCurrentPrice" Text="Preis: 25.00§" X="10" Y="55" FontSize="12" Color="#9ca3af"/>
    
    <InputField Name="SellQuantityInput" X="10" Y="80" Width="150" Height="30" 
                Placeholder="Anzahl" TextInputType="number"/>
    <Text Name="TotalRevenue" Text="Erlös: 0§" X="10" Y="115" FontSize="14" Color="#ffffff"/>
    
    <Button Name="ConfirmSell" Text="Verkaufen" X="10" Y="150" Width="130" Height="35" 
            Background="#ef4444" Color="#ffffff" OnClick="confirm_sell"/>
    <Button Name="CancelSell" Text="Abbrechen" X="155" Y="150" Width="130" Height="35" 
            Background="#6b7280" Color="#ffffff" OnClick="cancel_dialog"/>
  </Dialog>
  
  <!-- EINZAHLEN Dialog -->
  <Dialog Name="DepositDialog" Width="300" Height="180" Background="#1f2937" Modal="true">
    <Text Name="DepositTitle" Text="Geld einzahlen" X="10" Y="10" FontSize="16" Color="#ffffff"/>
    <InputField Name="DepositAmountInput" X="10" Y="40" Width="200" Height="35" 
                Placeholder="Betrag in §" TextInputType="number"/>
    <Button Name="ConfirmDeposit" Text="Einzahlen" X="10" Y="90" Width="130" Height="35" 
            Background="#3b82f6" Color="#ffffff" OnClick="confirm_deposit"/>
    <Button Name="CancelDeposit" Text="Abbrechen" X="155" Y="90" Width="130" Height="35" 
            Background="#6b7280" Color="#ffffff" OnClick="cancel_dialog"/>
  </Dialog>

</Root>
