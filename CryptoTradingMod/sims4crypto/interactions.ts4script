        sims4.log.info("CryptoMod", "  - Geld: {}".format(HOUSEHOLD_FUNDS))
        sims4.log.info("CryptoMod", "  - Buffs: {}, {}, {}".format(BUFF_FOCUSED_HIGH, BUFF_HAPPY, BUFF_SAD_HIGH))
    except Exception as e:
        pass


