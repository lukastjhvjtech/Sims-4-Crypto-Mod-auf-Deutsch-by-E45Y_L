# Helper-Funktionen für UI-Aktionen
def deposit_funds(sim, amount):
    """Zahle Geld ein - nutzt official householdFunds"""
    household_id = sim.household.id
    account = get_account(household_id)
    success = account.deposit(amount)
    return success


def withdraw_funds(sim, amount):
    """Hebe Geld ab"""
    household_id = sim.household.id
    account = get_account(household_id)
    success = account.withdraw(amount)
    return success


def buy_crypto(sim, crypto_name, quantity):
    """Kaufe Krypto"""
    household_id = sim.household.id
    account = get_account(household_id)
    success = account.buy_crypto(crypto_name, quantity)
    if success:
        account.add_xp(XP_REWARDS["buy_crypto"])
    return success


def sell_crypto(sim, crypto_name, quantity):
    """Verkaufe Krypto"""
    household_id = sim.household.id
    account = get_account(household_id)
    success = account.sell_crypto(crypto_name, quantity)
    if success:
        account.add_xp(XP_REWARDS["sell_crypto"])
    return success
